FROM ubuntu:24.04

ARG HDF5_VERSION=1.12.2
ARG HDF5_TAG=hdf5-1_12_2
ARG HDF5_FLAVOR=serial
ARG HDF5_PARALLEL=OFF
ARG HDF5_PREFIX=/opt/hdf5

ENV DEBIAN_FRONTEND=noninteractive
ENV OMPI_ALLOW_RUN_AS_ROOT=1
ENV OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
ENV OMPI_MCA_rmaps_base_oversubscribe=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends eatmydata && \
    eatmydata apt-get install -y --no-install-recommends \
        ca-certificates \
        cmake \
        curl \
        g++ \
        gcc \
        make \
        ninja-build \
        openmpi-bin \
        libopenmpi-dev \
        pkg-config \
        zlib1g-dev && \
    rm -rf /var/lib/apt/lists/*

RUN /bin/bash -o pipefail -c 'set -eux; \
    src="/tmp/hdf5-${HDF5_VERSION}"; \
    build="/tmp/hdf5-build-${HDF5_VERSION}-${HDF5_FLAVOR}"; \
    prefix="${HDF5_PREFIX}/${HDF5_VERSION}/${HDF5_FLAVOR}"; \
    mkdir -p "${src}"; \
    curl -fsSL "https://github.com/HDFGroup/hdf5/archive/refs/tags/${HDF5_TAG}.tar.gz" \
        | tar -xz --no-same-owner --no-same-permissions --strip-components=1 -C "${src}"; \
    if [[ "${HDF5_PARALLEL}" == "ON" ]]; then \
        export CC=mpicc CXX=mpicxx; \
    fi; \
    cmake -S "${src}" -B "${build}" -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="${prefix}" \
        -DBUILD_SHARED_LIBS=ON \
        -DBUILD_TESTING=OFF \
        -DHDF5_BUILD_CPP_LIB=OFF \
        -DHDF5_BUILD_EXAMPLES=OFF \
        -DHDF5_BUILD_FORTRAN=OFF \
        -DHDF5_BUILD_HL_LIB=ON \
        -DHDF5_BUILD_JAVA=OFF \
        -DHDF5_BUILD_TOOLS=ON \
        -DHDF5_ENABLE_PARALLEL="${HDF5_PARALLEL}"; \
    cmake --build "${build}" --parallel; \
    cmake --install "${build}"; \
    rm -rf "${src}" "${build}"'

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 && \
    rm -rf /var/lib/apt/lists/*

ENV HDF5_ROOT=${HDF5_PREFIX}/${HDF5_VERSION}/${HDF5_FLAVOR}
ENV PATH=${HDF5_PREFIX}/${HDF5_VERSION}/${HDF5_FLAVOR}/bin:${PATH}
ENV LD_LIBRARY_PATH=${HDF5_PREFIX}/${HDF5_VERSION}/${HDF5_FLAVOR}/lib:${LD_LIBRARY_PATH}

COPY docker/hdf5/run-h5cpp-tests.sh /usr/local/bin/run-h5cpp-tests
COPY docker/mpi-CMakeLists.txt /opt/h5cpp/mpi-CMakeLists.txt
RUN chmod +x /usr/local/bin/run-h5cpp-tests

WORKDIR /src
CMD ["run-h5cpp-tests"]
